<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="robots" content="nosnippet">
        <meta name="keywords" content="<%= meta.keywords %>">
        <meta name="author" content="<%= meta.name %>">
        <meta name="robots" content="max-snippet:0">
        <meta name="description" content="<%= meta.description %>">
        <meta property="og:description" content="<%= meta.description %>">
        <meta property="og:type" content="website">
        <meta property="og:title" content="<%= meta.title %>">
        <meta property="og:url" content="<%= meta.url %>">
        <meta name="twitter:card" content="summary">
        <meta property="twitter:title" content="<%= meta.title %>">
        <meta name="theme-color" content="<%= meta.theme.dark %>" media="(prefers-color-scheme: dark)">
        <meta name="theme-color" content="<%= meta.theme.light %>" media="(prefers-color-scheme: light)">
        <title><%= meta.title %></title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="icon" href="<%= meta.favicon %>">
        <link rel="apple-touch-icon" href="<%= meta.favicon %>">
        <% for tag in htmlRspackPlugin.tags.headTags { %>
          <% if tag.tagName == "link" { %>
            <%= toHtml(tag) %>
          <% } %>
          <% if tag.tagName == "script" { %>
            <%= toHtml(tag) %>
          <% } %>
        <% } %>
    </head>
    <body>
        <header>
            <a href="#" class="title" title="Title -- press to scroll to top">uint.dev</a>
            <span class="options">
                <a href="https://blog.uint.dev/" class="button-link" title="Blog">
                    <span class="blog-icon"></span>
                </a>
                <a href="#" class="theme-invert hide" title="Invert theme">
                    <span class="theme-invert-icon"></span>
                </a>
            </span>
        </header>
        <main>
            <div class="init-blk">
                <div class="splash-blk">
                    <div class="splash-info">
                        <div class="picture"></div>
                        <div class="about">Developer &bull; Designer &bull; Security</div>
                        <div class="button-container">
                            <% for item in contact { %>
                              <a href="<%= item.url %>"  class="button-link" title="<%= item.name %>"><%= item.name %></a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
            <section id="about">
                <div class="content-title">About me</div>
                <div class="content-block">
                    <div class="sub-info">
                        <%= aboutData %>
                    </div>
                </div>
            </section>
            <section id="projects">
                <div class="content-title"><%= project.metadata.title %></div>
                <div class="content-desc"><%= project.metadata.description %></div>
                <div class="content-block">
                    <div class="card-container">
                        <% for item in project.list { %>
                            <a href="<%= item.url %>" class="card">
                                <div class="project-info">
                                    <div class="name"><%= item.name %></div>
                                    <div class="tag-container">
                                        <% for tag in item.tags { %>
                                            <span class="tag"><%= tag %></span>
                                        <% } %>
                                    </div>
                                    <div class="description"><%= item.description %></div>
                                </div>
                            </a>
                        <% } %>
                    </div>
                </div>
            </section>
            <section id="blog">
                <div class="content-title"><%= blog.metadata.title %></div>
                <div class="content-desc"><%= blog.metadata.description %></div>
                <div class="content-block">
                    <div class="card-container">
                        <% for post in blog.posts { %>
                            <a class="card" href="<%= blog.metadata.base + post.link %>">
                                <div class="blog-info">
                                    <div class="title"><%= post.title %></div>
                                    <div class="description"><%= post.description %></div>
                                    <div class="metadata"><%= post.metadata %></div>
                                </div>
                            </a>
                        <% } %>
                    </div>
                </div>
            </section>
            <dialog>
                <div class="header"></div>
                <div class="body"></div>
                <a href="#" class="close">Close</a>
            </dialog>
        </main>
        <footer>
            <div class="content">
                <div class="label">made with <span class="heart">&#10084;</span></div>
                <a href="<%= commitURL %>/commit/<%= commitFull %>" title="View latest commit on GitHub" class="commit">
                    <span class="git-icon-container"><span class="git-icon"></span></span>
                    <span class="commit-id"><%= commitIDPartial %></span>
                </a>
            </div>
        </footer>
        <% for tag in htmlRspackPlugin.tags.bodyTags { %>
          <%= toHtml(tag) %>
        <% } %>
    </body>
</html>
